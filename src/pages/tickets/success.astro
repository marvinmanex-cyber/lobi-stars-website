---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Your Tickets | Lobi Stars Football Club">
  <div class="page-content wrap" style="max-width:720px;padding-top:150px;min-height:50vh;">
    <div id="state-loading">
      <div class="stag">Please Wait</div>
      <h1 class="stitle">Confirming <span class="r">Payment</span></h1>
      <p class="muted">This usually takes a few seconds...</p>
    </div>

    <div id="state-success" style="display:none;">
      <div class="stag">Booking Confirmed</div>
      <h1 class="stitle">Your <span class="r">Tickets</span></h1>
      <p id="summary" class="muted" style="margin-bottom:28px;"></p>
      <div id="ticket-list"></div>
      <p class="muted" style="margin-top:24px;font-size:13px;">
        A copy of each ticket has also been emailed to you. Present the QR code once at the gate &mdash; one scan per ticket.
      </p>
      <div style="display:flex;gap:14px;flex-wrap:wrap;margin-top:20px;">
        <a href="/tickets" class="btn-p" style="display:inline-block;">Buy Tickets for Another Match &rarr;</a>
        <a href="/" class="btn-o" style="display:inline-block;">&larr; Back to Home</a>
      </div>
    </div>

    <div id="state-error" style="display:none;">
      <div class="stag">Something's Not Right</div>
      <h1 class="stitle">Payment Not <span class="r">Confirmed</span></h1>
      <p id="error-msg" class="muted"></p>
      <a href="/tickets" class="btn-o" style="margin-top:20px;display:inline-block;">&larr; Back to Tickets</a>
    </div>
  </div>
</Layout>

<style>
  .tix-card{
    display:flex;background:linear-gradient(135deg,#7a0f14,#3a0708);
    border-radius:14px;overflow:hidden;margin-bottom:22px;
    box-shadow:0 16px 40px -12px rgba(0,0,0,.5);
    border:2px solid var(--gold);
  }
  .tix-main{flex:1;padding:24px 22px;color:#fff;position:relative;min-width:0;}
  .tix-main::after{
    content:'';position:absolute;inset:6px;border:1px solid rgba(255,199,44,.35);
    border-radius:8px;pointer-events:none;
  }
  .tix-brand{display:flex;align-items:center;gap:10px;margin-bottom:4px;}
  .tix-brand img{width:34px;height:34px;border-radius:50%;border:1.5px solid var(--gold);background:#fff;}
  .tix-brand-name{font-family:'Bebas Neue',sans-serif;font-size:15px;letter-spacing:2px;color:var(--gold);}
  .tix-tagline{font-size:9px;letter-spacing:3px;text-transform:uppercase;color:rgba(255,255,255,.55);margin-bottom:14px;}
  .tix-teams{font-family:'Bebas Neue',sans-serif;font-size:clamp(22px,5vw,30px);line-height:1.05;letter-spacing:1px;margin-bottom:12px;text-wrap:balance;}
  .tix-teams .vs{color:var(--gold);font-size:14px;margin:0 6px;}
  .tix-meta{font-size:13px;line-height:1.7;color:rgba(255,255,255,.85);margin-bottom:14px;}
  .tix-meta strong{color:#fff;}
  .tix-id{font-family:ui-monospace,monospace;font-size:12px;letter-spacing:.5px;color:rgba(255,255,255,.6);}
  .tix-stub{
    width:150px;flex-shrink:0;background:rgba(0,0,0,.22);padding:22px 16px;
    display:flex;flex-direction:column;align-items:center;text-align:center;
    position:relative;
  }
  .tix-perf{
    width:1px;position:relative;background:repeating-linear-gradient(to bottom,rgba(255,199,44,.5) 0 6px,transparent 6px 12px);
  }
  .tix-perf::before,.tix-perf::after{
    content:'';position:absolute;left:50%;transform:translateX(-50%);width:16px;height:16px;
    border-radius:50%;background:var(--dark);
  }
  .tix-perf::before{top:-8px;}
  .tix-perf::after{bottom:-8px;}
  .tix-admit{font-family:'Bebas Neue',sans-serif;font-size:15px;letter-spacing:2px;color:var(--gold);margin-bottom:10px;}
  .tix-qr{background:#fff;padding:8px;border-radius:6px;margin-bottom:10px;}
  .tix-qr svg{display:block;width:110px;height:110px;}
  .tix-tier{font-family:'Barlow Condensed',sans-serif;font-size:12px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:#fff;margin-bottom:2px;}
  .tix-price{font-family:'Bebas Neue',sans-serif;font-size:18px;color:var(--gold);}
  .tix-download{
    margin-top:12px;background:rgba(255,199,44,.15);border:1px solid var(--gold);color:var(--gold);
    font-family:'Barlow Condensed',sans-serif;font-size:11px;font-weight:700;letter-spacing:1px;text-transform:uppercase;
    padding:8px 14px;border-radius:5px;cursor:pointer;width:100%;
  }
  .tix-download:hover{background:var(--gold);color:#1a0a00;}
  @media(max-width:520px){
    .tix-card{flex-direction:column;}
    .tix-stub{width:100%;flex-direction:row;flex-wrap:wrap;justify-content:center;padding:18px;}
    .tix-perf{width:100%;height:1px;background:repeating-linear-gradient(to right,rgba(255,199,44,.5) 0 6px,transparent 6px 12px);}
    .tix-perf::before,.tix-perf::after{top:50%;transform:translateY(-50%);}
    .tix-perf::before{left:-8px;}
    .tix-perf::after{left:auto;right:-8px;}
  }
</style>

<script is:inline>
(async function () {
  const params = new URLSearchParams(window.location.search);
  const reference = params.get('reference') || params.get('trxref');
  const loading = document.getElementById('state-loading');
  const success = document.getElementById('state-success');
  const errorState = document.getElementById('state-error');
  const errorMsg = document.getElementById('error-msg');

  if (!reference) {
    loading.style.display = 'none';
    errorState.style.display = 'block';
    errorMsg.textContent = 'No payment reference was provided.';
    return;
  }

  try {
    const res = await fetch(`/api/verify?reference=${encodeURIComponent(reference)}`);
    const data = await res.json();

    if (!res.ok || data.error || data.status !== 'success') {
      loading.style.display = 'none';
      errorState.style.display = 'block';
      errorMsg.textContent = data.error || 'Payment could not be confirmed. If you were charged, contact us with your reference: ' + reference;
      return;
    }

    const ev = data.event;
    const dateObj = new Date(ev.event_date);
    const dateStr = dateObj.toLocaleDateString('en-GB', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });
    const timeStr = dateObj.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' });
    const tierPriceKobo = data.order.totalKobo / data.order.quantity;

    document.getElementById('summary').textContent =
      `${ev.home_team} vs ${ev.away_team} — ${data.order.tier} × ${data.order.quantity} — Order ${data.order.id}`;

    const list = document.getElementById('ticket-list');
    data.tickets.forEach((ticketId, i) => {
      const card = document.createElement('div');
      card.className = 'tix-card';
      card.id = `tix-card-${i}`;
      card.innerHTML = `
        <div class="tix-main">
          <div class="tix-brand"><img src="/images/hero-6.jpg" alt="Lobi Stars Badge"/><span class="tix-brand-name">LOBI STARS FOOTBALL CLUB</span></div>
          <div class="tix-tagline">Glory to Glory</div>
          <div class="tix-teams">${ev.home_team}<span class="vs">VS</span>${ev.away_team}</div>
          <div class="tix-meta">
            <strong>${dateStr}</strong><br/>
            Kick-off: <strong>${timeStr}</strong><br/>
            Venue: <strong>${ev.venue}</strong>
          </div>
          <div class="tix-id">TICKET NO: ${ticketId}</div>
        </div>
        <div class="tix-perf"></div>
        <div class="tix-stub">
          <div class="tix-admit">ADMIT ONE</div>
          <div class="tix-qr" id="qr-${i}"></div>
          <div class="tix-tier">${data.order.tier}</div>
          <div class="tix-price">&#8358;${(tierPriceKobo / 100).toLocaleString()}</div>
          <button class="tix-download" onclick="downloadTicket(${i})">&#8681; Download Ticket</button>
        </div>
      `;
      list.appendChild(card);
    });

    loading.style.display = 'none';
    success.style.display = 'block';

    // QR + download rendering via lightweight CDN scripts (no ticket data
    // ever leaves the browser -- these only draw/rasterize what's already here).
    const qrScript = document.createElement('script');
    qrScript.src = 'https://cdn.jsdelivr.net/npm/qrcode-generator@1.4.4/qrcode.min.js';
    qrScript.onload = () => {
      data.tickets.forEach((ticketId, i) => {
        const qr = qrcode(0, 'M');
        qr.addData(ticketId);
        qr.make();
        document.getElementById(`qr-${i}`).innerHTML = qr.createSvgTag({ scalable: true });
      });
    };
    document.body.appendChild(qrScript);

    const html2canvasScript = document.createElement('script');
    html2canvasScript.src = 'https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js';
    document.body.appendChild(html2canvasScript);

    window.downloadTicket = function (i) {
      const el = document.getElementById(`tix-card-${i}`);
      const btn = el.querySelector('.tix-download');
      const originalText = btn.textContent;
      btn.textContent = 'Generating...';
      html2canvas(el, { backgroundColor: null, scale: 2 }).then(canvas => {
        const link = document.createElement('a');
        link.download = `lobi-stars-ticket-${data.tickets[i]}.png`;
        link.href = canvas.toDataURL('image/png');
        link.click();
        btn.textContent = originalText;
      }).catch(() => { btn.textContent = originalText; });
    };
  } catch (err) {
    loading.style.display = 'none';
    errorState.style.display = 'block';
    errorMsg.textContent = 'Network error while confirming payment. Please refresh this page.';
  }
})();
</script>
