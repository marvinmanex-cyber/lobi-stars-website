---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Your Tickets | Lobi Stars Football Club">
  <div class="page-content wrap" style="max-width:720px;padding-top:150px;min-height:50vh;">
    <div id="state-loading">
      <div class="stag">Please Wait</div>
      <h1 class="stitle">Confirming <span class="r">Payment</span></h1>
      <p class="muted">This usually takes a few seconds...</p>
    </div>

    <div id="state-success" style="display:none;">
      <div class="stag">Booking Confirmed</div>
      <h1 class="stitle">Your <span class="r">Tickets</span></h1>
      <p id="summary" class="muted" style="margin-bottom:28px;"></p>
      <div id="ticket-list"></div>
      <p class="muted" style="margin-top:24px;font-size:13px;">
        A copy of each ticket has also been emailed to you. Present the QR code once at the gate &mdash; one scan per ticket.
      </p>
      <div style="display:flex;gap:14px;flex-wrap:wrap;margin-top:20px;">
        <a href="/tickets" class="btn-p" style="display:inline-block;">Buy Tickets for Another Match &rarr;</a>
        <a href="/" class="btn-o" style="display:inline-block;">&larr; Back to Home</a>
      </div>
    </div>

    <div id="state-error" style="display:none;">
      <div class="stag">Something's Not Right</div>
      <h1 class="stitle">Payment Not <span class="r">Confirmed</span></h1>
      <p id="error-msg" class="muted"></p>
      <a href="/tickets" class="btn-o" style="margin-top:20px;display:inline-block;">&larr; Back to Tickets</a>
    </div>
  </div>
</Layout>

<style is:global>
  .tix-card{
    display:flex;background:linear-gradient(160deg,#0d1a33,#0a1226);
    border-radius:14px;overflow:hidden;margin-bottom:22px;
    box-shadow:0 16px 40px -12px rgba(0,0,0,.5);
    border:2px solid #C9A227;
  }
  .tix-main{flex:1;padding:22px 22px 18px;color:#fff;position:relative;min-width:0;}
  .tix-main::after{
    content:'';position:absolute;inset:6px;border:1px solid rgba(201,162,39,.35);
    border-radius:8px;pointer-events:none;
  }
  .tix-league{font-size:9px;letter-spacing:3px;text-transform:uppercase;color:rgba(255,255,255,.55);text-align:center;margin-bottom:4px;}
  .tix-title{font-family:'Bebas Neue',sans-serif;font-size:15px;letter-spacing:2px;color:#C9A227;text-align:center;margin-bottom:16px;}
  .tix-crests{display:flex;align-items:center;justify-content:center;gap:18px;margin-bottom:10px;}
  .tix-crests img{width:52px;height:52px;object-fit:contain;background:#fff;border-radius:50%;padding:4px;}
  .tix-vs{font-family:'Bebas Neue',sans-serif;font-size:16px;color:#C9A227;}
  .tix-teams{font-family:'Bebas Neue',sans-serif;font-size:clamp(18px,4.5vw,24px);line-height:1.1;letter-spacing:1px;margin-bottom:14px;text-align:center;text-wrap:balance;}
  .tix-teams .vs{color:#C9A227;font-size:13px;margin:0 6px;}
  .tix-infobar{background:rgba(255,255,255,.92);border-radius:8px;padding:12px 14px;margin-bottom:12px;display:flex;justify-content:space-around;gap:8px;flex-wrap:wrap;text-align:center;}
  .tix-infobar div{flex:1;min-width:90px;}
  .tix-infobar .k{font-size:9px;letter-spacing:1.5px;text-transform:uppercase;color:#5a6270;margin-bottom:3px;}
  .tix-infobar .v{font-family:'Barlow',sans-serif;font-weight:700;font-size:12px;color:#0d1a33;}
  .tix-id{font-family:ui-monospace,monospace;font-size:11px;letter-spacing:.5px;color:rgba(255,255,255,.5);text-align:center;}
  .tix-stub{
    width:160px;flex-shrink:0;background:rgba(255,255,255,.94);color:#0d1a33;padding:18px 14px;
    display:flex;flex-direction:column;align-items:center;text-align:center;
    position:relative;
  }
  .tix-perf{
    width:1px;position:relative;background:repeating-linear-gradient(to bottom,rgba(201,162,39,.6) 0 6px,transparent 6px 12px);
  }
  .tix-perf::before,.tix-perf::after{
    content:'';position:absolute;left:50%;transform:translateX(-50%);width:16px;height:16px;
    border-radius:50%;background:var(--dark);
  }
  .tix-perf::before{top:-8px;}
  .tix-perf::after{bottom:-8px;}
  .tix-stub-label{font-family:'Bebas Neue',sans-serif;font-size:12px;letter-spacing:2px;color:#0d1a33;margin-bottom:10px;}
  .tix-qr{background:#fff;padding:6px;border:1px solid #e2e6ed;border-radius:6px;margin-bottom:8px;}
  .tix-qr svg{display:block;width:100px;height:100px;}
  .tix-verify{font-size:9px;color:#5a6270;line-height:1.5;margin-bottom:12px;}
  .tix-verify strong{display:block;color:#0d1a33;font-size:10px;letter-spacing:1px;text-transform:uppercase;margin-bottom:2px;}
  .tix-tier-badge{width:44px;height:44px;object-fit:contain;margin-bottom:4px;}
  .tix-tier{font-family:'Barlow Condensed',sans-serif;font-size:11px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:#0d1a33;margin-bottom:2px;}
  .tix-price{font-family:'Bebas Neue',sans-serif;font-size:18px;color:#0d1a33;margin-bottom:10px;}
  .tix-barcode{width:100%;height:28px;background:repeating-linear-gradient(90deg,#0d1a33 0,#0d1a33 2px,transparent 2px,transparent 4px,#0d1a33 4px,#0d1a33 5px,transparent 5px,transparent 8px);margin-bottom:4px;}
  .tix-bcid{font-family:ui-monospace,monospace;font-size:8px;letter-spacing:1px;color:#5a6270;margin-bottom:12px;word-break:break-all;}
  .tix-download{
    background:#0d1a33;border:1px solid #0d1a33;color:#C9A227;
    font-family:'Barlow Condensed',sans-serif;font-size:11px;font-weight:700;letter-spacing:1px;text-transform:uppercase;
    padding:8px 14px;border-radius:5px;cursor:pointer;width:100%;
  }
  .tix-download:hover{background:#C9A227;color:#0d1a33;border-color:#C9A227;}
  @media(max-width:520px){
    .tix-card{flex-direction:column;}
    .tix-stub{width:100%;flex-direction:row;flex-wrap:wrap;justify-content:center;padding:18px;}
    .tix-perf{width:100%;height:1px;background:repeating-linear-gradient(to right,rgba(201,162,39,.6) 0 6px,transparent 6px 12px);}
    .tix-perf::before,.tix-perf::after{top:50%;transform:translateY(-50%);}
    .tix-perf::before{left:-8px;}
    .tix-perf::after{left:auto;right:-8px;}
  }
</style>

<script is:inline>
(async function () {
  const params = new URLSearchParams(window.location.search);
  const reference = params.get('reference') || params.get('trxref');
  const loading = document.getElementById('state-loading');
  const success = document.getElementById('state-success');
  const errorState = document.getElementById('state-error');
  const errorMsg = document.getElementById('error-msg');

  if (!reference) {
    loading.style.display = 'none';
    errorState.style.display = 'block';
    errorMsg.textContent = 'No payment reference was provided.';
    return;
  }

  try {
    const res = await fetch(`/api/verify?reference=${encodeURIComponent(reference)}`);
    const data = await res.json();

    if (!res.ok || data.error || data.status !== 'success') {
      loading.style.display = 'none';
      errorState.style.display = 'block';
      errorMsg.textContent = data.error || 'Payment could not be confirmed. If you were charged, contact us with your reference: ' + reference;
      return;
    }

    const TEAM_LOGOS = {
      'Lobi Stars': '/images/lobi-stars-crest.png',
      'Kano Pillars': '/images/kano-pillars-logo.png',
    };
    const TIER_LABELS = { VIP: 'VIP Sitting', Premium: 'Cover Stand', Regular: 'Popular Stand' };
    const TIER_BADGES = { VIP: '/images/vip-siting.png', Premium: '/images/cover-stand.png', Regular: '/images/popular-stand.png' };
    function crestImg(name) {
      const src = TEAM_LOGOS[name];
      return src
        ? `<img src="${src}" alt="${name}"/>`
        : `<div style="width:52px;height:52px;border-radius:50%;background:#1e2f52;color:#fff;display:flex;align-items:center;justify-content:center;font-family:'Bebas Neue',sans-serif;font-size:20px;">${name.charAt(0)}</div>`;
    }

    const ev = data.event;
    const dateObj = new Date(ev.event_date);
    const dateStr = dateObj.toLocaleDateString('en-GB', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });
    const timeStr = dateObj.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', hour12: true });
    const tierLabel = TIER_LABELS[data.order.tier] || data.order.tier;
    const tierBadge = TIER_BADGES[data.order.tier];
    const tierPriceKobo = data.order.totalKobo / data.order.quantity;

    document.getElementById('summary').textContent =
      `${ev.home_team} vs ${ev.away_team} — ${tierLabel} × ${data.order.quantity} — Order ${data.order.id}`;

    const list = document.getElementById('ticket-list');
    data.tickets.forEach((ticketId, i) => {
      const card = document.createElement('div');
      card.className = 'tix-card';
      card.id = `tix-card-${i}`;
      card.innerHTML = `
        <div class="tix-main">
          <div class="tix-league">Nigeria Professional Football League</div>
          <div class="tix-title">Official Match Ticket</div>
          <div class="tix-crests">${crestImg(ev.home_team)}<span class="tix-vs">VS</span>${crestImg(ev.away_team)}</div>
          <div class="tix-teams">${ev.home_team}<span class="vs">VS</span>${ev.away_team}</div>
          <div class="tix-infobar">
            <div><div class="k">Date</div><div class="v">${dateStr}</div></div>
            <div><div class="k">Kick-off</div><div class="v">${timeStr}</div></div>
            <div><div class="k">Venue</div><div class="v">${ev.venue}</div></div>
          </div>
          <div class="tix-id">TICKET NO: ${ticketId}</div>
        </div>
        <div class="tix-perf"></div>
        <div class="tix-stub">
          <div class="tix-stub-label">MATCH TICKET</div>
          <div class="tix-qr" id="qr-${i}"></div>
          <div class="tix-verify"><strong>&#128274; Verify Ticket</strong>Scan the QR code to confirm this ticket is genuine.</div>
          ${tierBadge ? `<img class="tix-tier-badge" src="${tierBadge}" alt="${tierLabel}"/>` : ''}
          <div class="tix-tier">${tierLabel}</div>
          <div class="tix-price">&#8358;${(tierPriceKobo / 100).toLocaleString()}</div>
          <div class="tix-barcode"></div>
          <div class="tix-bcid">${ticketId}</div>
          <button class="tix-download" onclick="downloadTicket(${i})">&#8681; Download Ticket</button>
        </div>
      `;
      list.appendChild(card);
    });

    loading.style.display = 'none';
    success.style.display = 'block';

    // QR + download rendering via lightweight CDN scripts (no ticket data
    // ever leaves the browser -- these only draw/rasterize what's already here).
    const qrScript = document.createElement('script');
    qrScript.src = 'https://cdn.jsdelivr.net/npm/qrcode-generator@1.4.4/qrcode.min.js';
    qrScript.onload = () => {
      data.tickets.forEach((ticketId, i) => {
        const qr = qrcode(0, 'M');
        qr.addData(`${location.origin}/verify/${ticketId}`);
        qr.make();
        document.getElementById(`qr-${i}`).innerHTML = qr.createSvgTag({ scalable: true });
      });
    };
    document.body.appendChild(qrScript);

    // Loaded lazily from a CDN, so the click handler below must wait for it
    // rather than assume it's ready -- a fast tap on "Download Ticket" right
    // after the page renders can otherwise fire before the script arrives,
    // throwing before any .then/.catch exists to recover and leaving the
    // button stuck on "Generating..." forever.
    let html2canvasReady = null;
    function loadHtml2Canvas() {
      if (!html2canvasReady) {
        html2canvasReady = new Promise((resolve, reject) => {
          if (window.html2canvas) { resolve(window.html2canvas); return; }
          const s = document.createElement('script');
          s.src = 'https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js';
          s.onload = () => resolve(window.html2canvas);
          s.onerror = () => reject(new Error('Could not load the ticket image generator.'));
          document.body.appendChild(s);
        });
      }
      return html2canvasReady;
    }
    loadHtml2Canvas().catch(() => {}); // start loading eagerly; errors surface on actual download attempts

    window.downloadTicket = async function (i) {
      const el = document.getElementById(`tix-card-${i}`);
      const btn = el.querySelector('.tix-download');
      const originalText = btn.textContent;
      btn.disabled = true;
      btn.textContent = 'Generating...';
      try {
        const html2canvasFn = await loadHtml2Canvas();
        const canvas = await html2canvasFn(el, { backgroundColor: null, scale: 2, useCORS: true });
        const link = document.createElement('a');
        link.download = `lobi-stars-ticket-${data.tickets[i]}.png`;
        link.href = canvas.toDataURL('image/png');
        link.click();
      } catch (err) {
        alert('Could not generate the ticket image. Please check your connection and try again, or take a screenshot of the ticket instead.');
      } finally {
        btn.disabled = false;
        btn.textContent = originalText;
      }
    };
  } catch (err) {
    loading.style.display = 'none';
    errorState.style.display = 'block';
    errorMsg.textContent = 'Network error while confirming payment. Please refresh this page.';
  }
})();
</script>
