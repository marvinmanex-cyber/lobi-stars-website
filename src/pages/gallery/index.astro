---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const photos = (await getCollection('gallery')).sort(
  (a, b) => b.id.localeCompare(a.id)
);
---
<Layout title="Photo Gallery | Lobi Stars Football Club">
  <div class="page-hero wrap">
    <div class="stag">Moments</div>
    <h1 class="stitle">Photo <span class="r">Gallery</span></h1>
    <div class="divr"></div>
  </div>

  <div class="page-content wrap">
    {photos.length === 0 && (
      <div class="empty-state">
        No photos added yet &mdash; upload match albums via <a href="/admin" style="color:var(--gold);">/admin</a>.
      </div>
    )}
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:14px;">
      {photos.map(photo => (
        <div class="card" style="height:200px;position:relative;">
          <img src={photo.data.photo} alt={photo.data.caption} style="width:100%;height:100%;object-fit:cover;"/>
          <div style="position:absolute;bottom:0;left:0;right:0;background:rgba(0,0,0,.6);color:rgba(255,255,255,.85);font-size:11px;font-family:'Barlow Condensed',sans-serif;letter-spacing:1px;padding:8px 10px;">
            {photo.data.caption}
          </div>
        </div>
      ))}
    </div>
  </div>
</Layout>
